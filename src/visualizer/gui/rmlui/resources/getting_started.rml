<rml>
<head>
  <link type="text/template" href="floating_window.rml"/>
  <link type="text/rcss" href="getting_started.rcss"/>
</head>
<body template="floating-window" data-model="getting_started">

  <span class="panel-title">@tr:getting_started.title</span>
  <div class="separator"></div>

  <p class="description">@tr:getting_started.description</p>

  <div class="video-grid">
    <div class="video-card" id="card-automotive"
         data-url="https://www.youtube.com/watch?v=FqYTKeI5K6I"
         data-event-click="open_url">
      <div class="card-body">
        <span class="play-icon">&#x25B6;</span>
      </div>
      <span class="card-title">@tr:getting_started.video_automotive</span>
    </div>
    <div class="video-card" id="card-intro"
         data-url="https://www.youtube.com/watch?v=b1Olu_IU1sM"
         data-event-click="open_url">
      <div class="card-body">
        <span class="play-icon">&#x25B6;</span>
      </div>
      <span class="card-title">@tr:getting_started.video_intro</span>
    </div>
    <div class="video-card" id="card-latest"
         data-url="https://www.youtube.com/watch?v=zWIzBHRc-60"
         data-event-click="open_url">
      <div class="card-body">
        <span class="play-icon">&#x25B6;</span>
      </div>
      <span class="card-title">@tr:getting_started.video_latest</span>
    </div>
    <div class="video-card" id="card-masks"
         data-url="https://www.youtube.com/watch?v=956qR8N3Xk4"
         data-event-click="open_url">
      <div class="card-body">
        <span class="play-icon">&#x25B6;</span>
      </div>
      <span class="card-title">@tr:getting_started.video_masks</span>
    </div>
    <div class="video-card" id="card-reality-scan"
         data-url="https://www.youtube.com/watch?v=JWmkhTlbDvg"
         data-event-click="open_url">
      <div class="card-body">
        <span class="play-icon">&#x25B6;</span>
      </div>
      <span class="card-title">@tr:getting_started.video_reality_scan</span>
    </div>
    <div class="video-card" id="card-colmap"
         data-url="https://www.youtube.com/watch?v=-3TBbukYN00"
         data-event-click="open_url">
      <div class="card-body">
        <span class="play-icon">&#x25B6;</span>
      </div>
      <span class="card-title">@tr:getting_started.video_colmap</span>
    </div>
    <div class="video-card" id="card-lichtfeld"
         data-url="https://www.youtube.com/watch?v=aX8MTlr9Ypc"
         data-event-click="open_url">
      <div class="card-body">
        <span class="play-icon">&#x25B6;</span>
      </div>
      <span class="card-title">@tr:getting_started.video_lichtfeld</span>
    </div>
  </div>

  <div class="separator"></div>

  <span id="wiki-section" class="section-label wiki-link"
        data-url="https://github.com/MrNeRF/LichtFeld-Studio/wiki"
        data-event-click="open_url">@tr:getting_started.wiki_section</span>

</body>
</rml>
